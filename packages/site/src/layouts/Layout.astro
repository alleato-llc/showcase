---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.tsx";
import { config } from "../lib/content";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const year = new Date().getFullYear();
const copyright = config.copyright ?? config.name;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/caveat.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <script is:inline>
      // Resolve the theme BEFORE first paint: stored choice wins, otherwise
      // follow the system — and keep following it live until the user picks.
      (() => {
        const saved = localStorage.getItem("showcase-theme");
        const media = matchMedia("(prefers-color-scheme: dark)");
        const apply = (mode) => (document.documentElement.dataset.theme = mode);
        apply(saved ?? (media.matches ? "dark" : "light"));
        media.addEventListener("change", (e) => {
          if (!localStorage.getItem("showcase-theme")) {
            apply(e.matches ? "dark" : "light");
          }
        });
      })();
    </script>
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <a class="wordmark" href="/">{config.name}</a>
        <nav>
          {(config.nav ?? []).map((link) => <a href={link.href}>{link.label}</a>)}
        </nav>
        <ThemeToggle client:load />
      </div>
    </header>

    <main id="top">
      <slot />
    </main>

    <footer class="site">
      <div class="wrap">
        <span>{config.footer?.left}</span>
        <span class="copyright">© {year} {copyright}</span>
        <span>{config.footer?.right}</span>
      </div>
    </footer>
  </body>
</html>
